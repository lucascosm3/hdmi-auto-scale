<?xml version="1.0"?>
<monitors version="2">
  <!-- Standalone: laptop display at 125% (scale 1.25 in GNOME / 1.6x1.6 in xrandr) -->
  <configuration>
    <logicalmonitor>
      <x>0</x>
      <y>0</y>
      <scale>1.25</scale>
      <primary>yes</primary>
      <monitor>
        <monitorspec>
          <connector>eDP-1</connector>
          <vendor>YOUR_VENDOR</vendor>
          <product>YOUR_PRODUCT</product>
          <serial>YOUR_SERIAL</serial>
        </monitorspec>
        <mode>
          <width>1920</width>
          <height>1080</height>
          <rate>60</rate>
        </mode>
      </monitor>
    </logicalmonitor>
  </configuration>

  <!-- With HDMI: laptop at 100% (scale 1), external monitor to the right -->
  <configuration>
    <logicalmonitor>
      <x>2560</x>
      <y>0</y>
      <scale>1</scale>
      <monitor>
        <monitorspec>
          <connector>HDMI-1</connector>
          <vendor>YOUR_VENDOR</vendor>
          <product>YOUR_PRODUCT</product>
          <serial>YOUR_SERIAL</serial>
        </monitorspec>
        <mode>
          <width>2560</width>
          <height>1080</height>
          <rate>60</rate>
        </mode>
      </monitor>
    </logicalmonitor>
    <logicalmonitor>
      <x>0</x>
      <y>0</y>
      <scale>1</scale>
      <primary>yes</primary>
      <monitor>
        <monitorspec>
          <connector>eDP-1</connector>
          <vendor>YOUR_VENDOR</vendor>
          <product>YOUR_PRODUCT</product>
          <serial>YOUR_SERIAL</serial>
        </monitorspec>
        <mode>
          <width>1920</width>
          <height>1080</height>
          <rate>60</rate>
        </mode>
      </monitor>
    </logicalmonitor>
  </configuration>
</monitors>